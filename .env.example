# Railway injects DATABASE_URL automatically when you add a Postgres service
# and link it to this service. No manual config needed.
DATABASE_URL=postgres://agi:aionima@localhost:5432/agi

# 32-byte hex key for AES-256-GCM token encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Service mode: "central" (hosted at id.aionima.ai) or "local" (self-hosted)
# ID_SERVICE_MODE=central

# Public base URL for OAuth redirects (auto-detected in most setups)
# AIONIMA_ID_BASE_URL=https://id.aionima.ai

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (from GitHub > Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth (from Discord Developer Portal > Applications > OAuth2)
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# HIVE-ID (central mode only — enable global entity registry)
# HIVE_ENABLED=false
# HIVE_REGISTRY_URL=https://id.aionima.ai

# Owner node connection (local mode only — points back to the AGI gateway)
# OWNER_NODE_URL=
# OWNER_NODE_API_KEY=

# Set automatically by Railway/Docker
NODE_ENV=production
PORT=3000
